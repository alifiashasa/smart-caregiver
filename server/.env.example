# ── Database (Neon) ───────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection Details → Connection string
# Change postgres:// → postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/caregiverdb

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
DB_ECHO=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

GROQ_API_KEY=your-groq-api-key-here

# ── Resend (Email OTP) ────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Smart Caregiver <onboarding@resend.dev>
EMAIL_OTP_EXPIRE_MINUTES=5

# ── Internal API ──────────────────────────────────────────────────────────
# Used to authenticate internal job endpoints (/internal/jobs/*)
INTERNAL_API_KEY=change-me-to-a-random-secret
# ── Seed Data ─────────────────────────────────────────────────────────────────
# Set password for the initial caregiver user seeded in the database.
# If left unset, a secure random password will be generated and printed to the console.
SEED_CAREGIVER_PASSWORD=password123

# ── FCM Push Notifications ──────────────────────────────────────────────────────
# Path to Firebase Admin SDK service account JSON key
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FCM_CREDENTIALS_PATH=config/firebase-service-account.json
# Set to true to disable push (e.g. in development or test)
# FCM_DISABLED=false
